rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isPortalCandidate() {
      return isAuth() &&
        exists(/databases/$(database)/documents/portalCandidates/$(request.auth.uid)) == false &&
        // check by email via custom claim or just trust auth
        request.auth.token.email != null;
    }

    function incomingData() {
      return request.resource.data;
    }

    function hasFields(fields) {
      return incomingData().keys().hasAll(fields);
    }

    // ── Internal platform collections ─────────────────────────────────────────
    // Full read/write access for any authenticated (internal) user

    match /contracts/{id}          { allow read, write: if isAuth(); }
    match /worklogs/{id}           { allow read, write: if isAuth(); }
    match /companies/{id}          { allow read, write: if isAuth(); }
    match /candidates/{id}         { allow read, write: if isAuth(); }
    match /meets/{id}              { allow read, write: if isAuth(); }
    match /people/{id}             { allow read, write: if isAuth(); }
    match /tribes/{id}             { allow read, write: if isAuth(); }
    match /projects/{id}           { allow read, write: if isAuth(); }
    match /crmCandidates/{id}      { allow read, write: if isAuth(); }
    match /projectCandidates/{id}  { allow read, write: if isAuth(); }
    match /deals/{id}              { allow read, write: if isAuth(); }
    match /aiUsage/{id}            { allow read: if isAuth(); allow write: if true; }

    // ── Activity & Notifications ──────────────────────────────────────────────

    // Activity log — append-only, authenticated users can read all
    match /activityLog/{id} {
      allow read:          if isAuth();
      allow create:        if isAuth()
        && hasFields(['action', 'entityType', 'entityId', 'entityName', 'actor', 'ts'])
        && incomingData().ts is number;
      allow update, delete: if false;
    }

    // Notifications — all internal users can read (query filters to own userId client-side)
    match /notifications/{id} {
      allow read:   if isAuth();
      allow create: if isAuth()
        && hasFields(['userId', 'title', 'body', 'entityType', 'entityId', 'type', 'read', 'actorUid', 'ts'])
        && incomingData().read == false
        && incomingData().ts is number;
      allow update: if isAuth()
        && incomingData().diff(resource.data).affectedKeys().hasOnly(['read'])
        && incomingData().read is bool;
      allow delete: if false;
    }

    // Users (team members) — read all auth users; write only own record
    match /users/{uid} {
      allow read:  if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ── Portal collections ────────────────────────────────────────────────────

    // Allowlist — read: any auth user (portal needs to check own entry)
    //             write: only internal (all auth users = internal in this app)
    match /portalCandidates/{id} {
      allow read:   if isAuth();
      allow create: if isAuth()
        && hasFields(['email', 'name', 'active', 'createdAt'])
        && incomingData().email  is string
        && incomingData().name   is string
        && incomingData().active is bool;
      allow update: if isAuth()
        // only 'active' field can be toggled (deactivation)
        && incomingData().diff(resource.data).affectedKeys().hasOnly(['active'])
        && incomingData().active is bool;
      allow delete: if isAuth();
    }

    // Submissions — candidate can read/create own; internal can read all
    match /portalSubmissions/{id} {
      allow read: if isAuth();
      allow create: if isAuth()
        && hasFields(['candidateId', 'candidateEmail', 'type', 'fileName', 'fileUrl', 'fileSize', 'month', 'status', 'uploadedAt'])
        // candidate can only create for themselves
        && incomingData().candidateId == request.auth.uid
        && incomingData().status      == 'pending'
        && incomingData().type        in ['invoice', 'timesheet']
        && incomingData().fileSize    is number
        && incomingData().fileSize    <= 20 * 1024 * 1024; // max 20 MB
      allow update: if isAuth()
        // only status can be updated (by internal admin)
        && incomingData().diff(resource.data).affectedKeys().hasOnly(['status'])
        && incomingData().status in ['pending', 'paid', 'rejected'];
      allow delete: if false;
    }

    // Audit log — append-only, no updates or deletes
    match /portalAuditLog/{id} {
      allow read:   if isAuth();
      allow create: if isAuth()
        && hasFields(['userId', 'email', 'action', 'timestamp'])
        && incomingData().action in ['login', 'upload'];
      allow update, delete: if false;
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
