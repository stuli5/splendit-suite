rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Portal uploads ────────────────────────────────────────────────────────
    // Path: portal/{userId}/{filename}

    match /portal/{userId}/{fileName} {
      // Candidate can upload only to their own folder
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size  <= 20 * 1024 * 1024           // max 20 MB
        && request.resource.contentType.matches('application/pdf|image/(jpeg|jpg|png)');

      // Candidate can read own files; internal users can read all
      allow read: if request.auth != null;

      // Nobody can delete via client (admin only via Firebase Console / Admin SDK)
      allow delete: if false;
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
